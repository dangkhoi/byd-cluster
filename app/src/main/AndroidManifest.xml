<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Đọc notification do user cấp trong Settings. WRITE_EXTERNAL_STORAGE chỉ để THU THẬP (lưu icon/HUD
         vào Download cho hội) trên Android 10 (legacy storage); user tự cấp khi vào màn Thu thập. -->
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" android:maxSdkVersion="29" />

    <!-- Dead-reckoning vá GPS trong hầm: đọc trạng thái GNSS thật (số vệ tinh) + bơm mock-location cho GMaps.
         ACCESS_MOCK_LOCATION không enforce runtime; phải chọn app làm "mock location app" trong Developer Options
         (no-root). FINE_LOCATION cấp runtime cho registerGnssStatusCallback. -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_MOCK_LOCATION" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!-- WAKE_LOCK: giữ CPU thức cho dead-reckon tick khi màn tắt (postDelayed uptimeMillis dừng lúc deep-sleep). -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <!-- R7: targetSdk 34 → FGS type=location cần perm riêng trên API 34+ (Seal API29 không enforce, khai cho đúng/khỏi crash nếu cài máy đời mới). -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Tự rebind nav listener sau khi khởi động lại máy (RebindReceiver). -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <!-- ADB loopback (socket 127.0.0.1:5555) để rebind listener từ trong app. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Nút nổi (bubble) đưa GMaps lên cluster: vẽ overlay trên app khác + foreground service giữ nút sống. -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <!-- liệt kê app cho picker "Chiếu app lên cụm". API29 không lọc; thêm để chắc trên API30+ (app sideload cá nhân). -->
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES" />

    <!-- allowBackup=false: app lưu ADB private key (adb.key/adb.pub) trong filesDir — key này grant shell
         localhost:5555. Bật backup sẽ để `adb backup`/auto-backup rút key ra ngoài → tắt để không lộ. -->
    <application
        android:allowBackup="false"
        android:icon="@drawable/ic_launcher"
        android:label="@string/app_name"
        android:requestLegacyExternalStorage="true"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">

        <!-- Màn điều khiển: bật/tắt, trạng thái, chọn nguồn, cấp quyền -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Card fallback (CHIẾM màn, MẤT đồng hồ) — chỉ dùng khi làn nav zin không lên.
             Launch qua `am start` (cờ display + component .ClusterNavActivity) từ uid shell/dadb 2000, KHÔNG in-process.
             exported=true BẮT BUỘC: BYD DiLink3 enforce export-check cho shell-uid → exported=false bị Permission
             Denial (VERIFY TRÊN XE 2026-07-20). -->
        <activity
            android:name=".ClusterNavActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:screenOrientation="landscape"
            android:resizeableActivity="true"
            android:configChanges="orientation|screenSize|screenLayout|density|smallestScreenSize|keyboardHidden"
            android:theme="@style/ClusterTheme" />

        <!-- Màn thu thập dữ liệu cho hội (icon mũi tên + bảng HUD). -->
        <activity
            android:name=".CollectActivity"
            android:exported="false"
            android:label="Thu thập (hội)" />

        <!-- Host CHUNG cho mọi ClusterModule (thí nghiệm). 1 dòng VĨNH VIỄN — thêm/xoá module không đụng đây. -->
        <activity
            android:name=".modules.ModuleHost"
            android:exported="false"
            android:label="Module (thí nghiệm)" />

        <!-- AUTOMATION ADB: chạy self-test mọi module + recon HAL headless. exported=true BẮT BUỘC — launch DUY NHẤT
             qua `adb shell am start` (uid shell 2000), KHÔNG có launch in-process. BYD DiLink3 ENFORCE export-check
             cho shell-uid → exported=false bị "Permission Denial: not exported from uid" (VERIFY TRÊN XE 2026-07-20). -->
        <activity
            android:name=".modules.AutotestActivity"
            android:exported="true"
            android:label="Autotest (ADB)" />


        <!-- MAP LÊN CLUSTER (projection qua dadb). exported=false: chống app khác kích projection (chiếm cluster) —
             nút trong MainActivity mở qua explicit intent; adb shell vẫn 'am start' được activity non-exported. -->
        <activity
            android:name=".modules.clustercast.ClusterCastActivity"
            android:exported="false"
            android:label="Map lên cluster" />

        <!-- Nút nổi (bubble): chạm đưa GMaps lên cluster. Foreground specialUse (không có type nào khớp hơn). -->
        <service
            android:name=".modules.clustercast.FloatingBubbleService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="cluster_map_bubble" />
        </service>

        <!-- MODULE vdmap (ngoại lệ: cần Activity riêng). Xoá module vdmap → xoá luôn dòng này. -->
        <activity
            android:name=".modules.vdmap.VdMapActivity"
            android:exported="false"
            android:launchMode="singleTop"
            android:screenOrientation="landscape"
            android:resizeableActivity="true"
            android:configChanges="orientation|screenSize|screenLayout|density|smallestScreenSize|keyboardHidden"
            android:theme="@style/ClusterTheme" />

        <!-- Service NỀN dead-reckoning vá GPS hầm (foreground type=location). Xoá module deadreckon → xoá dòng này. -->
        <service
            android:name=".modules.deadreckon.DeadReckonService"
            android:exported="false"
            android:foregroundServiceType="location" />

        <!-- Lắng nghe notification dẫn đường -->
        <service
            android:name=".NavNotificationListener"
            android:exported="false"
            android:label="@string/nav_listener_label"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
        </service>

        <!-- SELF-HEAL: tự bind lại nav listener sau khi cài đè / cập nhật / khởi động máy
             → KHÔNG còn phải mở app hay disallow→allow tay để lấy lại nav. -->
        <receiver
            android:name=".RebindReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED" />
                <action android:name="com.byd.clusternav.REBIND_WATCHDOG" />
            </intent-filter>
        </receiver>

        <!-- MODULE navaccess (booster): đọc UI GMaps trên màn -> tinh chỉnh cự ly tới rẽ. User tự bật trong
             Cài đặt > Hỗ trợ. Xoá module navaccess → xoá dòng <service> này + res/xml/nav_accessibility_config.xml. -->
        <service
            android:name=".modules.navaccess.NavAccessibilityService"
            android:exported="false"
            android:label="@string/acc_label"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/nav_accessibility_config" />
        </service>

    </application>
</manifest>
